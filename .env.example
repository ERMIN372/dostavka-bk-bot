# --- Обязательные переменные ---

# Токен Telegram-бота от @BotFather
TELEGRAM_BOT_TOKEN=

# Ключ API сервисного аккаунта Yandex Cloud (Api-Key)
YANDEX_API_KEY=

# Идентификатор каталога (folder) в Yandex Cloud
YANDEX_FOLDER_ID=

# --- Необязательные переменные (есть разумные значения по умолчанию) ---

# Модель YandexGPT. Можно короткое имя (yandexgpt-lite / yandexgpt)
# или полный URI (gpt://<folder_id>/<model>/latest). По умолчанию: yandexgpt-lite
YANDEX_GPT_MODEL=yandexgpt-lite

# Локальная модель эмбеддингов (sentence-transformers).
# По умолчанию: intfloat/multilingual-e5-large
EMBEDDING_MODEL_NAME=intfloat/multilingual-e5-large

# Путь к папке базы знаний (по умолчанию ./knowledge_base)
# KNOWLEDGE_BASE_DIR=
